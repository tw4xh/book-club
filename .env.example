# Secret used to sign session cookies. Set to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Where the local SQLite database file lives (relative to project root).
# In production you would swap the data layer for Supabase/Postgres instead.
DATABASE_FILE=data/book-club.db

# Optional Chinese ISBN metadata fallback. Used only after Google Books and
# Open Library miss, to conserve the free request quota.
TANSHU_API_KEY=
