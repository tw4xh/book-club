# Secret used to sign session cookies. REQUIRED in production: the app refuses to
# sign/verify sessions if this is unset or left at the default, since anyone could
# otherwise forge a login. Generate one with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# Postgres connection string. The app runs on PostgreSQL (Supabase in production).
#
# Local development (Docker container from the README):
#   postgres://bookclub:bookclub@localhost:5433/bookclub
#
# Supabase (Vercel/serverless): use the *pooled* "Transaction" connection string
# from Project Settings -> Database -> Connection string. It uses port 6543 and
# looks like:
#   postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://bookclub:bookclub@localhost:5433/bookclub

# Set to "disable" to turn off SSL (only for local Docker Postgres). Managed
# providers like Supabase require SSL, which is enabled automatically otherwise.
# PGSSL=disable

# Optional Chinese ISBN metadata fallback. Used only after Google Books and
# Open Library miss, to conserve the free request quota.
TANSHU_API_KEY=

# Optional AI chatbot recommendations. Leave disabled/blank to keep the
# assistant database-only and free.
AI_CHAT_ENABLED=false
GEMINI_API_KEY=
# Gemini model id. Free-tier friendly default; override to gemini-3.5-flash etc.
GEMINI_MODEL=gemini-3.1-flash-lite
# Daily request budget (requests per day) for the free tier. Once reached, the
# assistant answers from local data only until the next day.
GEMINI_DAILY_LIMIT=500

# Optional donation links/handles shown on the homepage. Leave blank to hide a
# method. Do not commit real personal payment details outside private env config.
DONATION_PAYPAL_EMAIL=
DONATION_PAYPAL_URL=
DONATION_VENMO_ID=
DONATION_WECHAT_ID=
